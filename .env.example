# Copy to `.env` and fill in. `.env` is gitignored — never commit a populated one.
#
# Nothing here is required for `npm test` / `npm run build` / `npm run lint`:
# the local Hardhat network needs no secrets. These only matter for deploys
# and Etherscan verification against a live network.

## RPC endpoint for the target network.
## Falls back to a public (rate-limited) Sepolia node when unset.
SEPOLIA_RPC_URL=

## Deployer key. TESTNET ONLY.
## For anything with real value, drop this and use the Hardhat keystore instead:
##   npx hardhat keystore set DEPLOYER_PRIVATE_KEY
DEPLOYER_PRIVATE_KEY=

## Block-explorer API key, used by `npx hardhat verify` / script/deploy/verifyAll.sh.
ETHERSCAN_API_KEY=
